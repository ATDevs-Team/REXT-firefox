{
  "manifest_version": 3,
  "name": "REXT",
  "version": "1.0.0",
  "description": "A community based slop-blocker for Roblox",
  "action": {
    "default_popup": "window.html",
    "default_icon": "REXTicon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://pastebin.com/*"
  ]
}